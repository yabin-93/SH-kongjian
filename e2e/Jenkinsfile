pipeline {
  agent { label 'windows-playwright' }

  tools {
    nodejs 'nodejs-24.17.0'
  }

  options {
    timestamps()
    disableConcurrentBuilds()
    timeout(time: 10, unit: 'MINUTES')
    buildDiscarder(logRotator(daysToKeepStr: '30', numToKeepStr: '30', artifactDaysToKeepStr: '30'))
    skipDefaultCheckout(true)
  }

  triggers {
    cron('TZ=Asia/Shanghai\nH 2 * * *')
  }

  parameters {
    string(name: 'BASE_URL', defaultValue: 'https://pt-test.mrstage.com/', description: 'Target test environment')
  }

  environment {
    CI = 'true'
    DINGTALK_KEYWORD = "\u81EA\u52A8\u5316\u6D4B\u8BD5"
    E2E_RUN_ID = "${JOB_NAME}-${BUILD_NUMBER}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install') {
      steps {
        dir('e2e') {
          bat 'npm run clean'
          bat 'npm ci'
          bat 'npm run verify:env'
          bat 'npx playwright install chromium'
        }
      }
    }

    stage('Static checks') {
      steps {
        dir('e2e') {
          bat 'npm run test:unit'
          bat 'npm run typecheck'
          bat 'npm run test:list'
        }
      }
    }

    stage('P0 smoke') {
      steps {
        withCredentials([
          usernamePassword(
            credentialsId: 'mrstage-e2e-admin',
            usernameVariable: 'E2E_ADMIN_USERNAME',
            passwordVariable: 'E2E_ADMIN_PASSWORD'
          )
        ]) {
          dir('e2e') {
            bat 'npm run test:smoke'
          }
        }
      }
    }
  }

  post {
    always {
      junit allowEmptyResults: true, testResults: 'e2e/output/results/**/junit.xml'
      script {
        if (fileExists('e2e/output/allure-results')) {
          allure(
            commandline: 'allure',
            includeProperties: false,
            jdk: '',
            reportBuildPolicy: 'ALWAYS',
            resultPolicy: 'LEAVE_AS_IS',
            results: [[path: 'e2e/output/allure-results']]
          )
        } else {
          echo 'No Allure results found; skipping Allure report.'
        }
      }
      script {
        if (fileExists('e2e/output/results')) {
          withCredentials([string(credentialsId: 'dingtalk-webhook', variable: 'DINGTALK_WEBHOOK')]) {
            withEnv(["BUILD_RESULT=${currentBuild.currentResult}"]) {
              dir('e2e') {
                bat 'npm run notify:dingtalk'
              }
            }
          }
        } else {
          echo 'No Playwright results found; skipping DingTalk notification.'
        }
      }
      archiveArtifacts allowEmptyArchive: true, artifacts: 'e2e/output/**/*', fingerprint: true
    }
  }
}
