{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"]
  },
  "include": ["playwright.config.ts", "pages/**/*.ts", "fixtures/**/*.ts", "support/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts"]
}
